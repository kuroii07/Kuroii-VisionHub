{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kuroii VisionHub",
  "version": "0.5.11",
  "identifier": "studio.visionhub.app",
  "build": {
    "beforeDevCommand": "powershell -ExecutionPolicy Bypass -File scripts/before_tauri_dev.ps1",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kuroii VisionHub",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "D:/AIGC/codex/Libray/**",
          "D:\\AIGC\\codex\\Libray\\**",
          "\\\\?\\D:\\AIGC\\codex\\Libray\\**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "icons/installer-header.bmp",
        "sidebarImage": "icons/installer-sidebar.bmp",
        "uninstallerHeaderImage": "icons/installer-header.bmp",
        "languages": [
          "SimpChinese"
        ],
        "displayLanguageSelector": false
      }
    }
  }
}
