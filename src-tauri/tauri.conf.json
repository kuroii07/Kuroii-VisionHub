{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VisionHub Studio",
  "version": "0.3.2",
  "identifier": "studio.visionhub.app",
  "build": {
    "beforeDevCommand": "powershell -ExecutionPolicy Bypass -File scripts/before_tauri_dev.ps1",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VisionHub Studio",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "icons/installer-header.bmp",
        "sidebarImage": "icons/installer-sidebar.bmp",
        "uninstallerHeaderImage": "icons/installer-header.bmp",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      }
    }
  }
}
