{
  "name": "visionhub-studio",
  "private": true,
  "version": "0.5.6",
  "type": "module",
  "description": "Kuroii-branded desktop AI image workflow studio for local-first provider, gallery, prompt, and inspiration workflows.",
  "scripts": {
    "dev": "vite",
    "tauri:dev": "tauri dev",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:provider": "npm run test",
    "tauri:build:exe": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build_test_exe.ps1",
    "tauri:build": "tauri build && powershell -ExecutionPolicy Bypass -File .\\scripts\\copy_release_exe.ps1",
    "smoke": "python scripts/smoke_check.py",
    "verify": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run_checks.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "lucide-react": "^0.560.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  }
}
